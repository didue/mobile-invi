{
  "name": "wedding-invitation",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,api -c blue,green \"npm:dev:next\" \"npm:dev:api\"",
    "dev:next": "next dev -p 3000",
    "dev:api": "json-server --watch src/data/db.json --port 8001",
    "build": "next build",
    "start": "concurrently -n next,api -c blue,green \"npm:start:next\" \"npm:start:api\"",
    "start:next": "next start -p 3000",
    "start:api": "json-server --watch src/data/db.json --port 8001",
    "lint": "eslint ."
  },
  "dependencies": {
    "concurrently": "^10.0.3",
    "js-confetti": "^0.13.1",
    "json-server": "^0.17.4",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
